# Server Configuration
PORT=5000
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# MongoDB Atlas Connection String
# IMPORTANT: 
# 1. Replace <db_password> with your actual database password
# 2. If your password contains special characters (@, #, %, etc.), URL-encode them:
#    - @ becomes %40
#    - # becomes %23
#    - % becomes %25
#    Example: Password "Pranesh270106@" should be "Pranesh270106%40"
# 3. Replace 'myapp' with your preferred database name
# Your connection string format:
MONGODB_URI=mongodb+srv://praneshr006_db_user:<db_password>@cluster0.dtpmwhm.mongodb.net/myapp?retryWrites=true&w=majority&appName=Cluster0

# Optional: JWT Secret (if you plan to add authentication)
# JWT_SECRET=your_super_secret_jwt_key_here

